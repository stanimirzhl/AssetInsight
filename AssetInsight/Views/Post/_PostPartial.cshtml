@using AssetInsight.Models.Post
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model IEnumerable<PostVM>

@foreach (var post in Model.OrderByDescending(x => x.CreatedAt).ThenByDescending(x => x.EditedAt))
{
    <div id="post-@post.Id" class="post-card @(post.IsLocked ? "locked" : "")">

        <div class="post-votes">
            <span class="vote-count">@post.ReactionsCount</span>
        </div>

        <div class="post-content">

            <div class="dropdown d-flex justify-content-end">
                <button class="btn-dots" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-three-dots"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item text-decoration-none" asp-action="Edit" asp-route-id="@post.Id">@Localizer["Edit"]</a></li>
                    <li>
                        <button type="button" class="dropdown-item text-danger"
                                data-bs-toggle="modal" data-bs-target="#deletePostModal"
                                data-post-id="@post.Id"
                                data-post-title="@post.Title">
                            @Localizer["Delete"]
                        </button>
                    </li>
                </ul>
            </div>

            <div class="post-meta">
                @if (post.AuthorUserName == "[deleted]")
                {
                    <span class="author">
                        @Localizer["PostedBy"] @post.AuthorUserName
                    </span>
                }
                else
                {
                    <span class="author">
                        @Localizer["PostedBy"]
                        <a class="text-decoration-none" asp-action="UserPosts" asp-controller="Post" asp-route-userName="@post.AuthorUserName">
                            @post.AuthorUserName
                        </a>
                    </span>
                }
                <span class="time-ago" data-time="@post.CreatedAt.ToUniversalTime().ToString("o")"></span>

                @if (post.EditedAt.HasValue)
                {
                    <span class="edited" data-time="@post.EditedAt.Value.ToUniversalTime().ToString("o")"></span>
                }

                @if (post.IsLocked)
                {
                    <span class="locked-badge">🔒 @Localizer["Locked"]</span>
                }
        </div>

        <h4>
            <a asp-action="Details" asp-route-id="@post.Id">
                @post.Title
            </a>
        </h4>

        <p class="post-preview">
            @(post.Content.Length > 200
                        ? post.Content.Substring(0, 200) + "..."
                        : post.Content)
        </p>

            <div class="post-footer">

                <span class="comments">
                    💬 @post.CommentsCount @Localizer["Comments"]
                </span>

                <button type="submit" class="btn-save js-save-btn" data-post-id="@post.Id">
                    ⭐ @Localizer["Save"]
                </button>

            @if (post.Tags.Any())
                {
                    <div class="tag-container">
                        @foreach (var tag in post.Tags)
                        {
                            <a asp-action="Index" asp-route-tag="@tag.Name" class="tag-link">
                                <span class="tag-pill">#@tag.Name</span>
                            </a>
                        }
                    </div>
                }
            </div>

        </div>
    </div>
}
