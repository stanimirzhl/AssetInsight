@model AssetInsight.Core.DTOs.Comment.CommentDto

<link rel="stylesheet" href="~/css/post/comment partial/comment-partial.css" />

<div class="comment-thread @(Model.ParentCommentId != null ? "is-reply" : "")" id="comment-container-@Model.Id">

    <div class="thread-line-container" onclick="toggleComment('@Model.Id')" title="Collapse thread">
        <div class="thread-line"></div>
    </div>

    <div class="comment-content-wrapper">
        <div class="comment-header d-flex align-items-center mb-1" onclick="toggleComment('@Model.Id')">
            <img src="https://ui-avatars.com/api/?name=@Model.AuthorName&background=random&size=18" class="author-avatar-sm me-2" />
            <span class="collapsed-icon me-2"><i class="bi bi-plus-square"></i></span>
            <span class="comment-author me-2">u/@Model.AuthorName</span>
            <span class="comment-date">@Model.CreatedOn.ToString("MMM dd")</span>
        </div>

        <div id="comment-body-wrapper-@Model.Id" class="comment-body-content">

            @if (Model.IsDeleted)
            {
                <div class="comment-text mb-2 text-muted fst-italic">
                    <i class="bi bi-trash me-1"></i> [Comment deleted]
                </div>

                <div class="comment-actions d-flex align-items-center gap-3">
                    @if (Model.ReplyCount > 0)
                    {
                        <button class="load-replies-btn" data-comment-id="@Model.Id">
                            <i class="bi bi-chevron-down"></i> @Model.ReplyCount Replies
                        </button>
                    }
                </div>
            }
            else
            {
                <div class="comment-text mb-2">@Model.Content</div>

                <div class="comment-actions d-flex align-items-center gap-3">
                    <div class="comment-voting d-flex align-items-center" id="voting-@Model.Id">
                        <button class="vote-btn-sm up @(Model.UserVote == true ? "active" : "")"
                                onclick="handleCommentVote('@Model.Id', true, this)">
                            <i class="bi bi-arrow-up"></i>
                        </button>
                        <span class="vote-count-sm">@Model.UpvoteCount</span>
                        <button class="vote-btn-sm down @(Model.UserVote == false ? "active" : "")"
                                onclick="handleCommentVote('@Model.Id', false, this)">
                            <i class="bi bi-arrow-down"></i>
                        </button>
                    </div>

                    <button type="button" class="btn-action" onclick="showReplyBox('@Model.Id', '@Model.AuthorName')">
                        <i class="bi bi-chat-left"></i> Reply
                    </button>

                    @if (User.Identity.IsAuthenticated)
                    {
                        @if (Model.IsAuthor)
                        {
                            <div class="author-controls d-flex align-items-center">
                                <span class="action-separator">•</span>
                                <button type="button" class="btn-comment-action edit-link" onclick="editComment('@Model.Id')">
                                    <i class="bi bi-pencil-fill"></i> Edit
                                </button>
                                <button type="button" class="btn-comment-action delete-link" onclick="deleteComment('@Model.Id')">
                                    <i class="bi bi-trash3-fill"></i> Delete
                                </button>
                            </div>
                        }
                    }

                    @if (Model.ReplyCount > 0)
                    {
                        <button class="load-replies-btn" data-comment-id="@Model.Id">
                            <i class="bi bi-chevron-down"></i> @Model.ReplyCount Replies
                        </button>
                    }
                </div>
            }

            <div id="reply-container-@Model.Id" class="mt-2"></div>
            <div id="replies-container-@Model.Id" class="replies-list mt-2"></div>
        </div>
    </div>
</div>

<script>
    function toggleComment(commentId) {
        const container = document.getElementById(`comment-container-${commentId}`);
        if (container) {
            container.classList.toggle('is-collapsed');

            if (container.classList.contains('is-collapsed')) {
                container.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
        }
    }
</script>