@using AssetInsight.Models.Post
@model PostFormModel

<link rel="stylesheet" href="~/css/login/login.css" />

<div class="container mt-5">
    <div class="post-create-container bg-dark text-white rounded-3 shadow-lg">
        <form asp-action="Add" method="post" enctype="multipart/form-data">
            <div class="p-4">
                <h4 class="mb-4">Създаване на публикация</h4>

                <input asp-for="Title" class="form-control bg-dark border-secondary text-white mb-3" placeholder="Заглавие" />

                <div class="reddit-uploader-box border-secondary mb-3" id="dropZone">
                    <div id="imageGallery" class="gallery-viewport position-relative h-100">
                        <div id="emptyState" class="text-center py-5">
                            <i class="bi bi-image" style="font-size: 3rem; color: #555;"></i>
                            <p class="text-muted">Качете снимки (Drag & Drop)</p>
                            <button type="button" id="addBtnEmpty" class="btn btn-outline-primary btn-sm rounded-pill">Добави</button>
                        </div>

                        <div id="previewContainer" class="d-none h-100 w-100 position-relative">
                            <div class="carousel-top-controls d-flex justify-content-between w-100 p-3">
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn-reddit-pill" onclick="document.getElementById('fileInput').click()">
                                        <i class="bi bi-images"></i> Add
                                    </button>
                                    <button type="button" class="btn-reddit-pill" data-bs-toggle="modal" data-bs-target="#editGalleryModal">
                                        <i class="bi bi-pencil"></i> Edit All
                                    </button>
                                </div>
                                <button type="button" class="btn-reddit-circle text-white" id="deleteCurrentBtn">
                                    <i class="bi bi-trash3"></i>
                                </button>
                            </div>

                            <div class="main-img-wrapper d-flex align-items-center justify-content-center h-100">
                                <img id="mainPreview" src="" class="img-fluid" style="max-height: 450px; object-fit: contain;" />
                            </div>

                            <button type="button" class="nav-arrow left" id="prevBtn"><i class="bi bi-chevron-left"></i></button>
                            <button type="button" class="nav-arrow right" id="nextBtn"><i class="bi bi-chevron-right"></i></button>

                            <div class="dot-container-wrapper">
                                <div id="dotIndicators" class="dot-capsule"></div>
                            </div>
                        </div>
                    </div>
                    <input type="file" id="fileInput" name="Images" multiple accept="image/*" class="d-none" />
                </div>

                <div class="modal fade" id="editGalleryModal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-xl modal-dialog-centered">
                        <div class="modal-content reddit-modal">
                            <div class="modal-header border-0">
                                <h5 class="modal-title">Edit gallery</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <div id="modalGrid" class="d-flex flex-wrap gap-3">
                                </div>
                                <div class="mt-4">
                                    <button type="button" class="btn-text-link" id="addMorePhotosBtn">
                                        <i class="bi bi-images"></i> Add more photos
                                    </button>
                                </div>
                            </div>
                            <div class="modal-footer border-0">
                                <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Back</button>
                                <button type="button" class="btn btn-primary rounded-pill px-4" data-bs-dismiss="modal">Save</button>
                            </div>
                        </div>
                    </div>
                </div>


                <textarea asp-for="Content" class="form-control bg-dark border-secondary text-white mb-3" rows="6" placeholder="Съдържание..."></textarea>

                <div class="d-flex justify-content-end gap-2 border-top border-secondary pt-3">
                    <a asp-action="Index" class="btn btn-outline-light rounded-pill">Отказ</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Публикувай</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/post-add.js"></script>
}
