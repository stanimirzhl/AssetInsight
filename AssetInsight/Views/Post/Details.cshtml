@using AssetInsight.Models.Post
@model PostDetailsViewModel

<link rel="stylesheet" href="~/css/post/post-details.css"/>

<div class="forum-bg py-4">
    <div class="container forum-container">
        <div class="row">
            <div class="col-lg-8">
                <article class="reddit-post-card @(Model.IsLocked ? "locked" : "") mb-3">
                    <div class="reddit-voting">
                        <button class="vote-btn up @(Model.UserVote == true ? "active" : "")"
                                onclick="handleVote('@Model.Id', true, this)">
                            <i class="bi bi-arrow-up-short"></i>
                        </button>

                        <span class="vote-count" id="post-score-@Model.Id">@Model.UpvoteCount</span>

                        <button class="vote-btn down @(Model.UserVote == false ? "active" : "")"
                                onclick="handleVote('@Model.Id', false, this)">
                            <i class="bi bi-arrow-down-short"></i>
                        </button>
                    </div>

                    <div class="reddit-post-body">
                        <div class="post-meta">
                            <img src="https://ui-avatars.com/api/?name=@Model.AuthorName&background=random" class="author-avatar" />
                            <span class="author">u/@Model.AuthorName</span>
                            <span class="dot">•</span>
                            <span class="date">@Model.CreatedAt.ToString("MMM dd")</span>
                            @if (Model.IsLocked)
                            {
                                <span class="locked-badge"><i class="bi bi-lock-fill"></i></span>
                            }
                        </div>

                        <h1 class="post-title">@Model.Title</h1>

                        <div class="tag-container mb-3">
                            @foreach (var tag in Model.Tags)
                            {
                                <a asp-action="Index" asp-controller="Post" asp-route-tag="@tag.Name" class="tag-pill">
                                    #@tag.Name
                                </a>
                            }
                        </div>

                        <div class="post-content-text">
                            @Model.Content
                        </div>

                        @if (Model.ImgUrls.Any())
                        {
                            <div id="postImageCarousel" class="carousel slide mt-3 mb-3 post-media-container" data-bs-ride="false">
                                <div class="carousel-inner rounded-3">
                                    @for (int i = 0; i < Model.ImgUrls.Count; i++)
                                    {
                                        <div class="carousel-item @(i == 0 ? "active" : "")">
                                            <img src="@Model.ImgUrls.ElementAt(i).ImgUrl" class="d-block w-100 carousel-img" alt="Post content">
                                        </div>
                                    }
                                </div>
                                @if (Model.ImgUrls.Count > 1)
                                {
                                    <button class="carousel-control-prev" type="button" data-bs-target="#postImageCarousel" data-bs-slide="prev">
                                        <span class="carousel-control-prev-icon"></span>
                                    </button>
                                    <button class="carousel-control-next" type="button" data-bs-target="#postImageCarousel" data-bs-slide="next">
                                        <span class="carousel-control-next-icon"></span>
                                    </button>
                                }
                            </div>
                        }

                        <div class="post-footer">
                            <button class="footer-btn"><i class="bi bi-chat-square-text"></i> @Model.Comments.TotalCount Comments</button>
                            <button class="footer-btn"><i class="bi bi-share"></i> Share</button>
                            <button class="footer-btn"><i class="bi bi-bookmark"></i> Save</button>
                        </div>
                    </div>
                </article>

                <div class="comment-section">
                    @if (!Model.IsLocked)
                    {
                        <div class="comment-box-container mb-4">
                            <div class="d-flex align-items-center mb-2">
                                <span class="small">Comment as <span class="text-primary fw-bold">@User.Identity.Name</span></span>
                            </div>
                            <textarea id="mainCommentInput" class="form-control" placeholder="What are your thoughts?" rows="4"></textarea>
                            <div class="comment-box-footer">
                                <button onclick="submitComment()" class="btn-reddit-post">Comment</button>
                            </div>
                        </div>
                    }

                    <div class="comment-sort-options mb-3 d-flex align-items-center gap-2">
                        <span class="text-muted small fw-bold text-uppercase">Sort By:</span>
                        <select id="commentSortSelect" class="form-select form-select-sm w-auto border-0 bg-transparent fw-bold" onchange="handleSortChange()">
                            <option value="best">Best</option>
                            <option value="newest">Newest</option>
                        </select>
                    </div>

                    <div id="comments-container">
                        @foreach (var comment in Model.Comments.Items)
                        {
                            @await Html.PartialAsync("_CommentPartial", comment)
                        }
                    </div>

                    <div id="infinite-scroll-sentinel" class="text-center p-4">
                        <div id="loader" class="spinner-border text-primary spinner-border-sm @(Model.Comments.HasNextPage ? "" : "d-none")" role="status"></div>

                        <div id="status-message" class="text-muted small @(Model.Comments.HasNextPage ? "d-none" : "")">
                            No more comments.
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 d-none d-lg-block">
                <div class="sidebar-card mb-3">
                    <div class="sidebar-header">Forum Information</div>
                    <div class="sidebar-body">
                        <p class="small text-muted">Welcome to the asset discussion forum. Use tags to filter specific financial instruments or topics.</p>
                        <div class="stats d-flex justify-content-between mb-3">
                            <div><strong>1.2k</strong><br /><small>Members</small></div>
                            <div><strong>42</strong><br /><small>Online</small></div>
                        </div>
                        <button class="btn btn-primary w-100 rounded-pill fw-bold">Create Post</button>
                    </div>
                </div>

                <div class="sidebar-card">
                    <div class="sidebar-header">Trending Tags</div>
                    <div class="sidebar-body p-2">
                        <div class="d-flex flex-wrap gap-1">
                            <span class="tag-pill">#investing</span>
                            <span class="tag-pill">#stocks</span>
                            <span class="tag-pill">#crypto</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()
<input type="hidden" id="currentSort" value="best" />
<input type="hidden" id="currentPage" value="1" />
<input type="hidden" id="currentPage" value="1" />
<input type="hidden" id="postId" value="@Model.Id" />
<input type="hidden" id="hasMore" value="@Model.Comments.HasNextPage.ToString().ToLower()" />

@section Scripts {
    <script src="~/js/post/post-details.js"></script>
}