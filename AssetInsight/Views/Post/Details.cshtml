@using AssetInsight.Models.Post
@model PostDetailsViewModel

<link rel="stylesheet" href="~/css/post/post-details.css" />
<link rel="stylesheet" href="~/css/post/forum.css" />
<div class="forum-bg py-5">
    <div class="container forum-container" style="max-width: 1100px;">
        <div class="row g-4">

            <div class="col-lg-8">

                <article class="post-card d-flex flex-column flex-sm-row @(Model.IsLocked ? "locked" : "") mb-4 p-0" style="border-radius: 16px;">

                    <div class="post-votes d-flex flex-column align-items-center pt-4 reddit-voting border-end" style="width: 70px; background-color: rgba(0,0,0,0.1);">
                        <button class="vote-btn up border-0 bg-transparent p-0 @(Model.UserVote == true ? "active" : "")" onclick="handleVote('@Model.Id', true, this)">
                            <i class="bi bi-caret-up-fill fs-3"></i>
                        </button>

                        <span class="vote-count fs-5 fw-bold my-2" id="post-score-@Model.Id" style="color: var(--text-main);">@Model.UpvoteCount</span>

                        <button class="vote-btn down border-0 bg-transparent p-0 @(Model.UserVote == false ? "active" : "")" onclick="handleVote('@Model.Id', false, this)">
                            <i class="bi bi-caret-down-fill fs-3"></i>
                        </button>
                    </div>

                    <div class="reddit-post-body flex-grow-1 p-4 p-md-5">

                        <div class="post-meta d-flex align-items-center flex-wrap gap-2 mb-3 text-muted small">
                            <img src="https://ui-avatars.com/api/?name=@Model.AuthorName&background=random" class="rounded-circle shadow-sm" width="28" height="28" alt="Avatar" />
                            <span class="fw-semibold">
                                <a asp-action="UserPosts" asp-route-userName="@Model.AuthorName" class="text-decoration-none" style="color: var(--accent);">
                                    u/@Model.AuthorName
                                </a>
                            </span>
                            <span class="opacity-50">•</span>
                            <span class="date fw-medium"><i class="bi bi-clock me-1"></i>@Model.CreatedAt.ToString("MMM dd, yyyy")</span>

                            @if (Model.IsLocked)
                            {
                                <span class="badge rounded-pill ms-2" style="background-color: rgba(239, 68, 68, 0.1); color: #ef4444;">
                                    <i class="bi bi-lock-fill me-1"></i> Locked
                                </span>
                            }
                        </div>

                        <h1 class="post-title fw-bolder mb-3" style="color: var(--text-main); font-size: 1.75rem; letter-spacing: -0.5px;">@Model.Title</h1>

                        @if (Model.Tags.Any())
                        {
                            <div class="tag-container d-flex flex-wrap gap-2 mb-4">
                                @foreach (var tag in Model.Tags)
                                {
                                    <a asp-action="Index" asp-controller="Post" asp-route-tag="@tag.Name" class="text-decoration-none">
                                        <span class="badge premium-tag px-3 py-2 rounded-pill">#@tag.Name</span>
                                    </a>
                                }
                            </div>
                        }

                        <div class="post-content-text mb-4" style="color: var(--text-main); font-size: 1.05rem; line-height: 1.7;">
                            @Model.Content
                        </div>

                        @if (Model.ImgUrls.Any())
                        {
                            <div id="postImageCarousel" class="carousel slide mt-4 mb-4 shadow-sm rounded-4 overflow-hidden" data-bs-ride="false" style="border: 1px solid var(--border);">
                                <div class="carousel-inner">
                                    @for (int i = 0; i < Model.ImgUrls.Count; i++)
                                    {
                                        <div class="carousel-item @(i == 0 ? "active" : "") bg-dark text-center">
                                            <img src="@Model.ImgUrls.ElementAt(i).ImgUrl" class="img-fluid" style="max-height: 500px; object-fit: contain;" alt="Post content">
                                        </div>
                                    }
                                </div>
                                @if (Model.ImgUrls.Count > 1)
                                {
                                    <button class="carousel-control-prev" type="button" data-bs-target="#postImageCarousel" data-bs-slide="prev">
                                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                    </button>
                                    <button class="carousel-control-next" type="button" data-bs-target="#postImageCarousel" data-bs-slide="next">
                                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                    </button>
                                }
                            </div>
                        }

                        <div class="post-footer d-flex flex-wrap gap-3 pt-4 mt-2 border-top" style="border-color: rgba(255,255,255,0.05) !important;">
                            <button class="btn action-btn border-0"><i class="bi bi-chat-square-text me-2"></i>@Model.CommentCount Comments</button>
                            <button class="btn action-btn js-share-btn border-0"
                                    data-title="@Model.Title"
                                    data-url="@Url.Action("Details", "Post", new { id = Model.Id }, Context.Request.Scheme)">
                                <i class="bi bi-share me-2"></i>Share
                            </button>
                            <button class="btn action-btn js-save-btn border-0 @(Model.UserHasSaved ? "active text-accent" : "")" data-post-id="@Model.Id">
                                <i class="bi @(Model.UserHasSaved ? "bi-bookmark-fill" : "bi-bookmark") me-2"></i>
                                <span class="save-text">@(Model.UserHasSaved ? "Saved" : "Save")</span>
                            </button>

                            @if (User.IsInRole("Admin") || User.IsInRole("Moderator"))
                            {
                                <button type="button" id="lock-post-btn" class="btn action-btn border-0 @(Model.IsLocked ? "text-success" : "text-warning") ms-auto">
                                    <i class="bi @(Model.IsLocked ? "bi-unlock-fill" : "bi-lock-fill") me-2"></i>
                                    <span id="lock-btn-text">@(Model.IsLocked ? "Unlock Post" : "Lock Post")</span>
                                </button>
                            }
                        </div>
                    </div>
                </article>

                <div class="comment-section p-4 p-md-5 rounded-4 shadow-sm" style="background-color: var(--bg-card); border: 1px solid var(--border);">

                    @if (!Model.IsLocked)
                    {
                        <div class="comment-box-container mb-5 p-3 rounded-3" style="background-color: rgba(0,0,0,0.1); border: 1px solid var(--border);">
                            <div class="d-flex align-items-center mb-2">
                                <span class="small text-muted">Comment as <span style="color: var(--accent); font-weight: 700;">@User.Identity.Name</span></span>
                            </div>
                            <textarea id="mainCommentInput" class="form-control bg-transparent text-white border-secondary mb-3" placeholder="What are your thoughts on this strategy?" rows="3" style="box-shadow: none;"></textarea>
                            <div class="d-flex justify-content-end">
                                <button onclick="submitComment()" class="btn btn-create py-2 px-4">Post Comment</button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert text-center mt-2 mb-5 rounded-4 shadow-sm" role="alert" style="background-color: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2);">
                            <i class="bi bi-lock-fill me-2 fs-5 align-middle"></i>
                            <span class="fw-semibold">This post has been locked by a moderator. New comments cannot be added.</span>
                        </div>
                    }

                    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
                        <h5 class="fw-bold m-0" style="color: var(--text-main);">Discussion</h5>
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-muted small fw-bold text-uppercase">Sort By:</span>
                            <select id="commentSortSelect" class="form-select form-select-sm border-0 shadow-none fw-bold" style="background-color: rgba(255,255,255,0.05); color: var(--text-main); width: 100px;" onchange="handleSortChange()">
                                <option value="best" class="text-dark">Best</option>
                                <option value="newest" class="text-dark">Newest</option>
                            </select>
                        </div>
                    </div>

                    <div id="comments-container">
                        @foreach (var comment in Model.Comments.Items)
                        {
                            @await Html.PartialAsync("_CommentPartial", comment)
                        }
                    </div>

                    <div id="infinite-scroll-sentinel" class="text-center p-4 mt-3">
                        <div id="loader" class="spinner-border text-info spinner-border-sm @(Model.Comments.HasNextPage ? "" : "d-none")" role="status"></div>
                        <div id="status-message" class="text-muted small fw-bold @(Model.Comments.HasNextPage ? "d-none" : "")">
                            <i class="bi bi-check2-circle me-1"></i> You've reached the end of the thread.
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 d-none d-lg-block">

                <div class="sidebar-card mb-4 p-4 rounded-4 shadow-sm" style="background-color: var(--bg-card); border: 1px solid var(--border);">
                    <h5 class="fw-bold mb-3 border-bottom pb-2" style="color: var(--text-main);"><i class="bi bi-info-circle text-muted me-2"></i>Forum Info</h5>
                    <p class="small text-muted mb-4" style="line-height: 1.6;">Welcome to the AssetInsight community. Discuss algorithms, market trends, and backtesting results. Keep it professional.</p>

                    <div class="d-flex justify-content-between mb-4 text-center">
                        <div class="p-3 rounded-3 flex-grow-1 me-2" style="background-color: rgba(255,255,255,0.03); border: 1px solid var(--border);">
                            <h4 class="fw-bolder m-0" style="color: var(--text-main);">@Model.TotalMembersFormatted</h4>
                            <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Members</small>
                        </div>
                        <div class="p-3 rounded-3 flex-grow-1 ms-2" style="background-color: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2);">
                            <h4 id="online-count" class="fw-bolder m-0" style="color: #10B981;">@Model.OnlineMembers</h4>
                            <small class="text-muted text-uppercase fw-bold" style="font-size: 0.7rem; color: #10B981 !important;">Online</small>
                        </div>
                    </div>

                    <a asp-action="Create" asp-controller="Post" class="btn btn-create w-100"><i class="bi bi-pencil-square me-2"></i>Create Post</a>
                </div>

                <div class="sidebar-card p-4 rounded-4 shadow-sm" style="background-color: var(--bg-card); border: 1px solid var(--border);">
                    <h5 class="fw-bold mb-3 border-bottom pb-2" style="color: var(--text-main);"><i class="bi bi-hash text-muted me-2"></i>Trending Tags</h5>
                    <div class="d-flex flex-wrap gap-2 mt-3">

                        @if (Model.TrendingTags != null && Model.TrendingTags.Any())
                        {
                            @foreach (var tag in Model.TrendingTags)
                            {
                                <a asp-action="Index" asp-controller="Post" asp-route-tag="@tag.Name" class="text-decoration-none">
                                    <span class="badge premium-tag px-3 py-2 rounded-pill">#@tag.Name</span>
                                </a>
                            }
                        }
                        else
                        {
                            <span class="text-muted small fst-italic">No trending tags yet.</span>
                        }

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()
<input type="hidden" id="currentSort" value="best" />
<input type="hidden" id="currentPage" value="1" />
<input type="hidden" id="postId" value="@Model.Id" />
<input type="hidden" id="hasMore" value="@Model.Comments.HasNextPage.ToString().ToLower()" />

@section Scripts {
    <script src="~/js/post/post-details.js"></script>
    <script>
        if (window.connection) {
            window.connection.on("UpdateOnlineCount", (count) => {
                const $el = $("#online-count");
                if ($el.length) {
                    $el.text(count);
                }
            });
        }

        $(document).ready(function() {
            $("#lock-post-btn").click(function () {
                var postId = $("#postId").val();
                var token = $('input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '/Post/ToggleLock',
                    type: 'POST',
                    data: {
                        id: postId,
                        __RequestVerificationToken: token
                    },
                    success: function (response) {
                        if (response.success) {
                            location.reload();
                        }
                    },
                    error: function (xhr) {
                        if (xhr.status === 403 || xhr.status === 401) {
                            alert("You do not have permission to perform this action.");
                        } else {
                            alert("An error occurred while updating the post.");
                        }
                    }
                });
            });
        });

        $(document).ready(function () {

            $('.js-share-btn').click(async function () {
                const $btn = $(this);
                const title = $btn.data('title');
                const url = $btn.data('url');
                const originalText = $btn.html();

                if (navigator.share) {
                    try {
                        await navigator.share({
                            title: title,
                            text: 'Check out this discussion on AssetInsight!',
                            url: url
                        });
                        console.log('Successfully shared');
                    } catch (err) {
                        //console.log('Share cancelled or failed:', err);
                    }
                }
                else if (navigator.clipboard) {
                    try {
                        await navigator.clipboard.writeText(url);

                        $btn.html('<i class="bi bi-check-circle-fill text-success me-2"></i>Copied!');

                        setTimeout(() => {
                            $btn.html(originalText);
                        }, 2000);

                    } catch (err) {
                        //console.error('Failed to copy text: ', err);
                        alert("Failed to copy link to clipboard.");
                    }
                }
                else {
                    alert("Copy this link to share: " + url);
                }
            });

        });
    </script>
}