@using AssetInsight.Models.Post
@model PostDetailsViewModel

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-body d-flex">
                    <div class="d-flex flex-column align-items-center me-3 p-2 bg-light rounded" style="width: 40px;">
                        <button class="btn btn-link p-0 text-muted"><i class="bi bi-arrow-up-circle-fill fs-4"></i></button>
                        <span class="fw-bold">@Model.UpvoteCount</span>
                        <button class="btn btn-link p-0 text-muted"><i class="bi bi-arrow-down-circle-fill fs-4"></i></button>
                    </div>

                    <div class="flex-grow-1">
                        <div class="text-muted small mb-2">
                            <span>Posted by u/@Model.AuthorName</span> •
                            <span>@Model.CreatedAt.ToShortDateString()</span>
                            @if (Model.IsLocked)
                            {
                                <span class="badge bg-warning text-dark ms-2"><i class="bi bi-lock"></i> Locked</span>
                            }
                        </div>

                        <h2 class="h4 fw-bold">@Model.Title</h2>

                        <div class="post-tags mb-3">
                            @foreach (var tag in Model.Tags)
                            {
                                <span class="badge rounded-pill bg-light text-dark border me-1">#@tag</span>
                            }
                        </div>

                        <div class="post-body mb-4">
                            @Model.Content
                        </div>

                        @if (Model.ImgUrls.Any())
                        {
                            <div class="post-images mb-3">
                                @foreach (var img in Model.ImgUrls)
                                {
                                    <img src="@img" class="img-fluid rounded border mb-2" alt="Post content" />
                                }
                            </div>
                        }

                        <div class="post-footer border-top pt-2 mt-3">
                            <button class="btn btn-sm btn-light text-muted"><i class="bi bi-chat-left"></i> @Model.Comments.Items.Count Comments</button>
                            <button class="btn btn-sm btn-light text-muted"><i class="bi bi-share"></i> Share</button>
                            <button class="btn btn-sm btn-light text-muted"><i class="bi bi-bookmark"></i> Save</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="comment-section">
                <h5 class="mb-3">Comments</h5>
                @if (!Model.IsLocked)
                {
                    <div class="mb-4">
                        <textarea class="form-control mb-2" placeholder="What are your thoughts?" rows="3"></textarea>
                        <button class="btn btn-primary btn-sm rounded-pill px-3">Comment</button>
                    </div>
                }

                <div class="comments-list">
                    @foreach (var comment in Model.Comments.Items)
                    {
                        @await Html.PartialAsync("_CommentPartial", comment)
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white">About Community</div>
                <div class="card-body">
                    <p class="small">Welcome to the discussion. Please follow the rules and be civil!</p>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="comments-container">
    @foreach (var comment in Model.Comments.Items)
    {
        @await Html.PartialAsync("_CommentPartial", comment)
    }
</div>

<div id="infinite-scroll-sentinel" class="text-center p-4">
    @if (Model.Comments.HasNextPage)
    {
        <div id="loader" class="spinner-border text-primary" role="status"></div>
    }
</div>

<input type="hidden" id="currentPage" value="1" />
<input type="hidden" id="postId" value="@Model.Id" />
<input type="hidden" id="hasMore" value="@Model.Comments.HasNextPage.ToString().ToLower()" />

@section Scripts {
    <script>
        // 1. Infinite Scroll Logic
        const observer = new IntersectionObserver(async (entries) => {
            const hasMore = document.getElementById('hasMore').value === "true";
            if (entries[0].isIntersecting && hasMore) {
                await loadMoreComments();
            }
        }, { threshold: 1.0 });

        observer.observe(document.getElementById('infinite-scroll-sentinel'));

        async function loadMoreComments() {
            const pageInput = document.getElementById('currentPage');
            const postId = document.getElementById('postId').value;
            let nextPage = parseInt(pageInput.value) + 1;

            const response = await fetch(`/Comment/GetMoreComments?postId=${postId}&pageIndex=${nextPage}`);
            if (response.status === 204) {
                document.getElementById('hasMore').value = "false";
                document.getElementById('infinite-scroll-sentinel').innerHTML = "No more comments.";
                return;
            }

            const html = await response.text();
            document.getElementById('comments-container').insertAdjacentHTML('beforeend', html);
            pageInput.value = nextPage;
        }

        // 2. Load Replies Logic
        document.addEventListener("click", async function (e) {
            if (e.target.classList.contains("load-replies-btn")) {
                const btn = e.target;
                const parentId = btn.dataset.commentId;
                const container = document.getElementById(`replies-container-${parentId}`);

                btn.innerHTML = "Loading...";
                const response = await fetch(`/COmment/GetReplies?parentId=${parentId}`);
                const html = await response.text();

                container.innerHTML = html;
                btn.remove(); // Remove button after replies are loaded
            }
        });
    </script>
}