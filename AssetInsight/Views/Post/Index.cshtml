@using AssetInsight.Core
@using AssetInsight.Models.Post
@using Microsoft.AspNetCore.Mvc.Localization
@model PagingModel<PostVM>
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "Forum";
}

<link rel="stylesheet" href="~/css/post/forum.css" />

<div class="forum-container">

    <div class="forum-header-card mb-4 p-4 rounded-4 shadow-sm position-relative overflow-hidden" style="background-color: var(--bg-card); border: 1px solid var(--border);">
        <div class="position-absolute top-0 end-0 rounded-circle" style="width: 200px; height: 200px; background: radial-gradient(circle, rgba(34, 211, 238, 0.1) 0%, transparent 70%); transform: translate(30%, -30%);"></div>

        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center position-relative z-index-1">
            <div>
                <h2 class="fw-bolder mb-1" style="color: var(--text-main); letter-spacing: -0.5px;">
                    <i class="bi bi-globe2 me-2 text-muted"></i>@Localizer["CommunityPosts"]
                </h2>
                <p class="text-muted small mb-0">Share strategies, discuss market trends, and learn from top traders.</p>
            </div>
            <div class="mt-3 mt-md-0">
                <a asp-action="Create" class="btn btn-create shadow-sm d-inline-flex align-items-center gap-2">
                    <i class="bi bi-pencil-square"></i> @Localizer["CreatePost"]
                </a>
            </div>
        </div>
    </div>

    <div id="post-list" class="d-flex flex-column gap-3">
        <partial name="_PostPartial" model="Model.Items" />
    </div>

    <template id="skeleton-template">
        <div class="post-card skeleton-card d-flex">
            <div class="skeleton-votes border-end"></div>
            <div class="skeleton-content flex-grow-1 p-4">
                <div class="d-flex justify-content-between mb-3">
                    <div class="skeleton-line skeleton-meta shimmer w-25 rounded-pill"></div>
                    <div class="skeleton-line shimmer w-10 rounded-pill"></div>
                </div>
                <div class="skeleton-line skeleton-title shimmer w-75 mb-3 rounded-2" style="height: 24px;"></div>
                <div class="skeleton-line skeleton-text shimmer w-100 mb-2 rounded-2"></div>
                <div class="skeleton-line skeleton-text shimmer w-75 rounded-2"></div>
            </div>
        </div>
    </template>

    <div id="loading-sentinel" class="d-flex justify-content-center align-items-center" style="height: 80px;"></div>
</div>

<div class="modal fade" id="deletePostModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered custom-delete-modal">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-body p-5 text-center position-relative">
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>

                <div class="mb-4 d-inline-flex justify-content-center align-items-center rounded-circle" style="width: 80px; height: 80px; background-color: rgba(239, 68, 68, 0.1); color: #ef4444;">
                    <i class="bi bi-exclamation-triangle fs-1"></i>
                </div>

                <h3 class="fw-bold mb-3" style="color: var(--text-main);">@Localizer["DeletePost"]</h3>
                <p class="text-muted mb-4">@Html.Raw(Localizer["DeleteWarning"].Value)</p>

                <div class="d-flex justify-content-center gap-3">
                    <button type="button" class="btn btn-go-back px-4" data-bs-dismiss="modal">@Localizer["GoBack"]</button>
                    <form id="deletePostForm" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-confirm-delete px-4 d-flex align-items-center gap-2">
                            <i class="bi bi-trash3"></i> @Localizer["Delete"]
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/post/post-index.js"></script>
}