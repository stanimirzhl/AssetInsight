@using AssetInsight.Core
@using AssetInsight.Models.Account
@using AssetInsight.Models.Post
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model UserPostsViewModel

<link rel="stylesheet" href="~/css/post/forum.css" />
@{
    var userName = ViewContext.RouteData.Values["userName"]?.ToString();
    ViewData["Title"] = $"u/{userName} - AssetInsight";
}

<div class="container py-4">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="profile-nav-card mb-4 shadow-sm">
                <ul class="nav nav-pills nav-fill p-1">
                    <li class="nav-item">
                        <a class="nav-link @(Model.Section == "posts" ? "active" : "")"
                           asp-action="UserPosts" asp-route-userName="@userName" asp-route-section="posts">
                            <i class="bi bi-stickies me-2"></i>@Localizer["Posts"]
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Model.Section == "comments" ? "active" : "")"
                           asp-action="UserPosts" asp-route-userName="@userName" asp-route-section="comments">
                            <i class="bi bi-chat-dots me-2"></i>@Localizer["Comments"]
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Model.Section == "saved" ? "active" : "")"
                           asp-action="UserPosts" asp-route-section="saved">
                            <i class="bi bi-bookmark me-2"></i>@Localizer["Saved"]
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Model.Section == "upvoted" ? "active" : "")"
                           asp-action="UserPosts" asp-route-section="upvoted">
                            @Localizer["Upvoted"]
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(Model.Section == "downvoted" ? "active" : "")"
                           asp-action="UserPosts" asp-route-section="downvoted">
                            @Localizer["Downvoted"]
                        </a>
                    </li>
                </ul>
            </div>

            <div class="sort-bar mb-3 d-flex align-items-center justify-content-between px-3 py-2 shadow-sm">
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-sort active"><i class="bi bi-brightness-high"></i> @Localizer["New"]</button>
                    <button class="btn btn-sm btn-sort"><i class="bi bi-fire"></i> @Localizer["Hot"]</button>
                </div>
                <div class="view-options d-none d-md-block">
                    <i class="bi bi-view-list text-muted"></i>
                </div>
            </div>

            <div id="posts-feed">
                @if (Model.Section == "posts")
                {
                    @if (Model.Posts?.Items.Any() == true)
                    {
                        <partial name="_PostPartial" model="Model.Posts.Items" />
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="bi bi- layers fs-1"></i>
                            <p>@Localizer["NoPostsYet"]</p>
                        </div>
                    }
                }
                else if (Model.Section == "comments")
                {
                    @if (Model.Comments?.Items.Any() == true)
                    {
                        @foreach (var comment in Model.Comments.Items)
                        {
                            <div class="card comment-card mb-3 shadow-sm border-0">
                                <div class="card-body">
                                    <div class="d-flex align-items-center mb-2 small">
                                        <i class="bi bi-chat-left-text me-2 text-primary"></i>
                                        <span class="text-muted">@userName @Localizer["commentedOn"]</span>
                                        <a asp-controller="Post" asp-action="Details" asp-route-id="@comment.PostId" class="ms-1 fw-bold text-decoration-none">
                                            "@comment.PostTitle"
                                        </a>
                                        <span class="mx-2">•</span>
                                        <span class="text-muted">@comment.PostCreatedAt.Value.ToString("MMM dd")</span>
                                    </div>
                                    <div class="comment-content ps-4 border-start">
                                        @comment.Content
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="bi bi-chat-square-dots fs-1"></i>
                            <p>@Localizer["NoCommentsYet"]</p>
                        </div>
                    }
                }
            </div>

            <div id="loading-sentinel" class="py-4 text-center" style="display: none;">
                <div class="spinner-grow text-primary spinner-grow-sm" role="status"></div>
            </div>
        </div>

        <div class="col-lg-4 d-none d-lg-block">
            <div class="sticky-top" style="top: 20px;">
                <div class="card user-profile-card border-0 shadow-sm overflow-hidden mb-3">
                    <div class="user-card-banner"></div>
                    <div class="card-body pt-0 text-center">
                        <div class="avatar-wrapper">
                            <img src="https://ui-avatars.com/api/?name=@userName&background=0D6EFD&color=fff&size=128"
                                 class="profile-avatar-img shadow-sm" alt="avatar" />
                        </div>
                        <h4 class="mt-2 mb-1 fw-bold">u/@userName</h4>
                        <p class="text-muted small mb-4">@@@userName.ToLower()</p>

                        <div class="d-grid gap-2">
                            <button class="btn btn-primary rounded-pill fw-bold py-2">
                                <i class="bi bi-person-plus-fill me-2"></i>@Localizer["Follow"]
                            </button>
                            <button class="btn btn-light rounded-pill fw-bold py-2 border">
                                <i class="bi bi-chat-right-text me-2"></i>@Localizer["Chat"]
                            </button>
                        </div>
                    </div>
                </div>

                <div class="footer-links-card p-3 shadow-sm border-0 small">
                    <div class="row g-2 mb-3">
                        <div class="col-6"><a href="#" class="link-secondary text-decoration-none">User Agreement</a></div>
                        <div class="col-6"><a href="#" class="link-secondary text-decoration-none">Privacy Policy</a></div>
                        <div class="col-6"><a href="#" class="link-secondary text-decoration-none">Content Policy</a></div>
                        <div class="col-6"><a href="#" class="link-secondary text-decoration-none">Help Center</a></div>
                    </div>
                    <div class="pt-3 border-top text-center text-muted">
                        © @DateTime.Now.Year AssetInsight, Inc.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // State Management
        let currentPage = 1;
        let isLoading = false;
        let hasMore = true;

        // Context Variables from Razor
        const userName = "@userName";
        const currentSection = "@Model.Section";

        // Elements
        const feed = document.getElementById('posts-feed');
        const sentinel = document.getElementById('loading-sentinel');

        /**
         * Uses IntersectionObserver for a smoother "infinite scroll"
         * experience compared to window.onscroll.
         */
        const observer = new IntersectionObserver((entries) => {
            const entry = entries[0];
            if (entry.isIntersecting && !isLoading && hasMore) {
                loadMoreContent();
            }
        }, {
            rootMargin: '200px' // Start loading before the user reaches the bottom
        });

        // Start watching the sentinel div
        observer.observe(sentinel);

        async function loadMoreContent() {
            isLoading = true;
            currentPage++;
            sentinel.style.display = 'block';

            try {
                // Construct URL with current section and page
                const url = `/${userName}?section=${currentSection}&page=${currentPage}`;

                const response = await fetch(url, {
                    headers: { "X-Requested-With": "XMLHttpRequest" }
                });

                // 204 No Content means we've reached the end
                if (response.status === 204) {
                    hasMore = false;
                    sentinel.innerHTML = `<div class="py-3 text-muted small">@Localizer["NoMoreContent"]</div>`;
                    observer.unobserve(sentinel);
                    return;
                }

                if (!response.ok) throw new Error("Network response was not ok");

                const html = await response.text();

                // Append new content with a slight fade-in effect
                const tempDiv = document.createElement('div');
                tempDiv.innerHTML = html;
                tempDiv.style.opacity = '0';

                feed.appendChild(tempDiv);

                // Trigger reflow for animation
                setTimeout(() => {
                    tempDiv.style.transition = 'opacity 0.3s ease';
                    tempDiv.style.opacity = '1';
                }, 10);

                isLoading = false;
            } catch (err) {
                console.error("Failed to load content:", err);
                isLoading = false;
                sentinel.style.display = 'none';
            }
        }

        /**
         * Helper: If you want the sort buttons to work via AJAX
         * without a full page reload, you can add listeners here.
         */
        document.querySelectorAll('.btn-sort').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.btn-sort').forEach(b => b.classList.remove('active'));
                this.classList.add('active');

                // Note: Logic for re-sorting would go here (typically resetting
                // currentPage to 1 and clearing the feed).
            });
        });
    </script>
}

<style>
    :root {
        --profile-accent: #0D6EFD;
        --card-bg: var(--bs-body-bg);
    }

    /* Tabs Styling */
    .profile-nav-card {
        background: var(--card-bg);
        border-radius: 12px;
        border: 1px solid var(--bs-border-color);
    }

    .nav-pills .nav-link {
        color: var(--bs-secondary-color);
        font-weight: 600;
        font-size: 0.9rem;
        border-radius: 8px;
        transition: all 0.2s ease;
    }

        .nav-pills .nav-link.active {
            background-color: var(--profile-accent);
            color: white;
        }

    /* Sort Bar */
    .sort-bar {
        background: var(--card-bg);
        border-radius: 10px;
        border: 1px solid var(--bs-border-color);
    }

    .btn-sort {
        border-radius: 20px;
        font-weight: 600;
        color: var(--bs-secondary-color);
        border: 1px solid transparent;
    }

        .btn-sort:hover, .btn-sort.active {
            background-color: var(--bs-tertiary-bg);
            color: var(--profile-accent);
        }

    /* Comment Cards */
    .comment-card {
        border-radius: 12px;
        transition: transform 0.15s ease;
    }

        .comment-card:hover {
            transform: translateY(-2px);
        }

    .comment-content {
        font-size: 0.95rem;
        color: var(--bs-body-color);
        border-color: var(--bs-primary-border-subtle) !important;
    }

    /* Sidebar & Avatar */
    .user-card-banner {
        height: 100px;
        background: linear-gradient(135deg, #0D6EFD 0%, #00d4ff 100%);
    }

    .avatar-wrapper {
        margin-top: -50px;
    }

    .profile-avatar-img {
        width: 100px;
        height: 100px;
        border-radius: 20px; /* Squircle style */
        border: 5px solid var(--card-bg);
        object-fit: cover;
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 5rem 1rem;
        background: var(--card-bg);
        border-radius: 12px;
        border: 2px dashed var(--bs-border-color);
        color: var(--bs-secondary-color);
    }

    .footer-links-card {
        background: var(--card-bg);
        border-radius: 12px;
    }
</style>