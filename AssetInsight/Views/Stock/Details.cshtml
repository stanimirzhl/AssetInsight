@using AssetInsight.Core.DTOs.Stock
@using Microsoft.AspNetCore.Mvc.Localization
@model StockHistoryDtoModel
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = $"{Model.Symbol} Market Data";
    var latestPrice = Model.History.LastOrDefault()?.ClosePrice ?? 0;
    var previousPrice = Model.History.FirstOrDefault()?.ClosePrice ?? 0;
    var percentChange = previousPrice > 0 ? ((latestPrice - previousPrice) / previousPrice) * 100 : 0;
    var isPositive = percentChange >= 0;
}

<div class="container-fluid mt-4 px-lg-5">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-4 gap-3">
        <div>
            <div class="d-flex align-items-center gap-3 mb-2">
                <h1 class="mb-0 fw-bolder" style="color: var(--text-main); font-size: 2.5rem; letter-spacing: -1px;">@Model.Symbol</h1>
                <span class="badge" style="background-color: var(--bg-card); color: var(--text-muted); border: 1px solid var(--border);">EQUITY</span>

                @if (User.Identity.IsAuthenticated)
                {
                    <button id="followBtn" data-symbol="@Model.Symbol" class="btn btn-sm rounded-pill px-3 shadow-sm @(Model.IsFollowing ? "btn-accent text-white" : "btn-outline-secondary")" style="transition: all 0.2s;">
                        <i class="bi @(Model.IsFollowing ? "bi-bell-fill" : "bi-bell") me-1"></i>
                        <span id="followText">@(Model.IsFollowing ? "Following" : "Follow")</span>
                    </button>
                }
            </div>

            <div class="d-flex align-items-baseline gap-2">
                <h2 class="mb-0 fw-bold" style="color: var(--text-main);">@latestPrice.ToString("C2")</h2>
                <span class="fw-bold fs-5" style="color: @(isPositive ? "#10B981" : "#EF4444");">
                    <i class="bi @(isPositive ? "bi-arrow-up-right" : "bi-arrow-down-right")"></i>
                    @Math.Abs(percentChange).ToString("F2")%
                </span>
                <span class="text-muted small ms-2">Past @Model.CurrentRange</span>
            </div>
        </div>

        <form asp-controller="Stock" asp-action="Details" method="get" class="d-flex shadow-sm" style="border-radius: 8px; overflow: hidden; border: 1px solid var(--border);">
            <input type="text" name="symbol" value="@Model.Symbol" class="form-control border-0 bg-transparent text-uppercase fw-bold px-3" style="width: 120px; color: var(--text-main);" placeholder="TICKER" required />
            <div style="width: 1px; background-color: var(--border);"></div>
            <select name="range" class="form-select border-0 bg-transparent fw-bold" style="width: 130px; color: var(--text-main); cursor: pointer;" onchange="this.form.submit()">
                <option value="1mo" selected="@(Model.CurrentRange == "1mo")">1 Month</option>
                <option value="3mo" selected="@(Model.CurrentRange == "3mo")">3 Months</option>
                <option value="6mo" selected="@(Model.CurrentRange == "6mo")">6 Months</option>
                <option value="1y" selected="@(Model.CurrentRange == "1y")">1 Year</option>
                <option value="5y" selected="@(Model.CurrentRange == "5y")">5 Years</option>
                <option value="max" selected="@(Model.CurrentRange == "max")">Max Data</option>
            </select>
            <button type="submit" class="btn px-3" style="background-color: var(--accent); color: var(--bg-main);"><i class="bi bi-search"></i></button>
        </form>
    </div>

    <div class="row g-4">

        <div class="col-xl-8 col-lg-7">
            <div class="card shadow-sm h-100" style="background-color: var(--bg-card); border: 1px solid var(--border); border-radius: 12px;">
                <div class="card-header border-bottom-0 bg-transparent pt-4 px-4 pb-0">
                    <h5 class="fw-bold m-0" style="color: var(--text-main);"><i class="bi bi-graph-up text-muted me-2"></i>Price Action</h5>
                </div>
                <div class="card-body px-2">
                    <div id="stockChart" style="min-height: 500px;"></div>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-lg-5">
            <div class="card shadow-sm h-100" style="background-color: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; display: flex; flex-direction: column;">

                <div class="card-header bg-transparent py-3 px-4" style="border-bottom: 1px solid var(--border);">
                    <h5 class="fw-bold m-0 d-flex align-items-center justify-content-between" style="color: var(--text-main);">
                        <span><i class="bi bi-newspaper text-muted me-2"></i>@Model.Symbol News</span>
                        <span class="badge" style="background-color: rgba(34, 211, 238, 0.1); color: var(--accent);">Live Feed</span>
                    </h5>
                </div>

                <div class="card-body p-0" style="overflow-y: auto; max-height: 550px; scrollbar-width: thin;">
                    @if (Model.CompanyNews.Any())
                    {
                        <div class="list-group list-group-flush rounded-bottom">
                            @foreach (var news in Model.CompanyNews)
                            {
                                <a href="@news.Url" target="_blank" class="list-group-item list-group-item-action p-4 news-feed-item" style="background-color: transparent; border-bottom: 1px solid var(--border);">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="small fw-bold text-uppercase" style="color: var(--accent);">@news.Source</span>
                                        <span class="small text-muted">@news.PublishedAt.ToString("MMM dd")</span>
                                    </div>
                                    <h6 class="fw-bold mb-2" style="color: var(--text-main); line-height: 1.4;">@news.Headline</h6>
                                    <p class="mb-0 text-muted small" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">@news.Summary</p>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center h-100 p-5 text-center opacity-50">
                            <i class="bi bi-inbox fs-1 mb-3"></i>
                            <h6 class="fw-bold" style="color: var(--text-main);">No recent news found</h6>
                            <p class="small text-muted">Check back later for updates on @Model.Symbol.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .news-feed-item {
        transition: background-color 0.2s ease;
    }

        .news-feed-item:hover {
            background-color: rgba(255, 255, 255, 0.03) !important;
        }

    input:focus, select:focus {
        outline: none !important;
        box-shadow: none !important;
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            var rawData = @Json.Serialize(Model.History);
            if (!rawData || rawData.length === 0) return;

            var chartData = rawData.map(x => ({
                x: new Date(x.date).getTime(),
                y: [x.open, x.high, x.low, x.closePrice]
            }));

            var options = {
                series: [{ name: 'Price', data: chartData }],
                chart: {
                    type: 'candlestick',
                    height: 500,
                    background: 'transparent',
                    toolbar: {
                        autoSelected: 'pan',
                        show: true,
                        tools: { download: false, selection: true, zoom: true, pan: true }
                    },
                    animations: { enabled: false }
                },
                plotOptions: {
                    candlestick: {
                        colors: {
                            upward: '#10B981',
                            downward: '#EF4444'
                        },
                        wick: { useFillColor: true }
                    }
                },
                xaxis: {
                    type: 'datetime',
                    labels: { style: { colors: '#9ca3af' } },
                    axisBorder: { show: false },
                    axisTicks: { show: false }
                },
                yaxis: {
                    tooltip: { enabled: true },
                    labels: {
                        formatter: (val) => "$" + val.toFixed(2),
                        style: { colors: '#9ca3af', fontWeight: 600 }
                    }
                },
                grid: {
                    borderColor: 'var(--border)',
                    strokeDashArray: 4,
                    xaxis: { lines: { show: true } },
                    yaxis: { lines: { show: true } },
                    padding: { left: 20, right: 20 }
                },
                tooltip: {
                    theme: 'dark',
                    x: { format: 'dd MMM yyyy' }
                }
            };

            var chart = new ApexCharts(document.querySelector("#stockChart"), options);
            chart.render();

            const followBtn = document.getElementById('followBtn');
            if(followBtn) {
                followBtn.addEventListener('click', function() {
                    const symbol = this.getAttribute('data-symbol');
                    fetch('/Stock/ToggleFollow', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                        },
                        body: JSON.stringify(symbol)
                    })
                    .then(res => res.json())
                    .then(data => {
                        if(data.success) {
                            const textSpan = document.getElementById('followText');
                            const icon = this.querySelector('i');
                            if(data.isFollowing) {
                                this.classList.remove('btn-outline-secondary');
                                this.classList.add('btn-accent', 'text-white');
                                icon.classList.replace('bi-bell', 'bi-bell-fill');
                                textSpan.innerText = 'Following';
                            } else {
                                this.classList.remove('btn-accent', 'text-white');
                                this.classList.add('btn-outline-secondary');
                                icon.classList.replace('bi-bell-fill', 'bi-bell');
                                textSpan.innerText = 'Follow';
                            }
                        }
                    });
                });
            }
        });
    </script>
}