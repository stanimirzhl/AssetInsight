@using AssetInsight.Models.Notification
@model IEnumerable<NotificationVM>

<ul id="notificationList" class="dropdown-menu dropdown-menu-end shadow" style="width: 300px; max-height: 400px; overflow-y: auto;">
    <li class="dropdown-header border-bottom">
        <div class="d-flex justify-content-between align-items-center">
            <span>Notification Center</span>
        </div>
    </li>

    @if (!Model.Any())
    {
        <li id="no-notifications-msg">
            <a class="dropdown-item text-center small text-muted py-3" href="#">No new notifications</a>
        </li>
    }

    @foreach (var item in Model)
    {
        <li>
            <a class="dropdown-item py-3 border-bottom notification-item @(item.IsRead ? "" : "bg-light")"
               data-id="@item.Id"
               href="@item.TargetUrl">
                <div class="d-flex flex-column">
                    <small class="text-muted">@item.CreatedAt.ToString("MMM dd, HH:mm")</small>
                    <span class="@(item.IsRead ? "" : "fw-bold")">@item.Message</span>
                </div>
            </a>
        </li>
    }

    <li>
        <a class="dropdown-item text-center small text-primary fw-bold" href="/Notifications">
            View All Notifications
        </a>
    </li>
</ul>