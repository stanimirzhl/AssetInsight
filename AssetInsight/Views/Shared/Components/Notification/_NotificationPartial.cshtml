@using AssetInsight.Models.Notification
@model IEnumerable<NotificationVM>

<ul id="notificationList" class="dropdown-menu dropdown-menu-end shadow"
    style="width: 300px; max-height: 400px; overflow-y: auto; background-color: var(--bg-card); border: 1px solid var(--border);">

    <li class="dropdown-header border-bottom" style="border-color: var(--border) !important; color: var(--text-muted);">
        Notification Center
    </li>

    @if (!Model.Any())
    {
        <li id="no-notifications-msg" class="text-center py-4" style="color: var(--text-muted);">
            <i class="bi bi-bell-slash fs-3 d-block mb-2"></i>
            <span class="small">You're all caught up!</span>
        </li>
    }

    @foreach (var item in Model)
    {
        <li>
            <a class="dropdown-item py-3 border-bottom notification-item @(item.IsRead ? "" : "notification-unread")"
               style="border-color: var(--border) !important; color: var(--text-main);"
               data-id="@item.Id"
               href="@item.TargetUrl">
                <div class="d-flex flex-column">
                    <small class="notification-date" style="color: var(--text-muted);">@item.CreatedAt.ToString("MMM dd, HH:mm")</small>
                    <span class="notification-text @(item.IsRead ? "" : "fw-bold")">
                        @item.Message
                    </span>
                </div>
            </a>
        </li>
    }

    <li>
        <button type="button" class="dropdown-item small fw-bold"
                style="color: var(--accent) !important;" id="viewAllBtn">
            View All Notifications
        </button>
    </li>
</ul>

<style>
    .notification-text {
        display: block;
        white-space: normal;
        overflow-wrap: break-word;
        line-height: 1.4;
    }

    .notification-unread {
        background-color: var(--bg-main) !important;
        border-left: 3px solid var(--accent) !important;
    }

    .dropdown-item:hover {
        background-color: var(--bg-main) !important;
        color: var(--text-main) !important;
    }
</style>