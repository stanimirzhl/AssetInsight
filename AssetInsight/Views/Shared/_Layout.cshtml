@using System.Globalization
@using Azure.Core
@using Microsoft.AspNetCore.Localization
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization
@inject IViewLocalizer Localizer
@{
    string currentCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
}

<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AssetInsight</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AssetInsight.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav id="mainNavbar" class="navbar navbar-expand-lg border-bottom shadow-sm sticky-top py-3" style="background-color: var(--bg-card, #ffffff); z-index: 1050;">
            <div class="container">
                <a class="navbar-brand fw-bold" style="color: var(--accent);" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-graph-up-arrow me-2"></i>AssetInsight
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between align-items-center">
                    <ul class="navbar-nav flex-grow-1 gap-2 ms-lg-4">
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-area="" asp-controller="Post" asp-action="Index">Posts</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-area="" asp-controller="Stock" asp-action="Details">Market</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link fw-semibold" asp-area="" asp-controller="Backtest" asp-action="Index">Backtest Strategies</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link fw-bold text-warning dropdown-toggle" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-shield-lock-fill me-1"></i> Admin Center
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark shadow" aria-labelledby="adminDropdown" style="background-color: var(--bg-card);">
                                    <li>
                                        <a class="dropdown-item" asp-area="Admin" asp-controller="Users" asp-action="Index">
                                            <i class="bi bi-people-fill me-2"></i> Manage Users
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Backtest" asp-action="Index">
                                            <i class="bi bi-strava me-2"></i> Manage Strategies
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Post" asp-action="Index">
                                            <i class="bi bi-sticky-fill me-2"></i> Manage Posts
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider border-secondary"></li>
                                    <li><span class="dropdown-item-text text-muted small">Admin Privileges Active</span></li>
                                </ul>
                            </li>
                        }
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown ms-lg-auto">
                                <a class="nav-link dropdown-toggle position-relative" href="#" id="notificationDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-bell-fill fs-5"></i>
                                    <span id="notification-count" class="position-absolute top-25 start-75 translate-middle badge rounded-pill bg-danger" style="display:none; font-size: 0.65rem;">
                                        0
                                    </span>
                                </a>
                                @await Component.InvokeAsync("Notification")
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-3 mt-3 mt-lg-0">
                        @*<button id="themeToggle" class="btn btn-outline-secondary btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                            <i class="bi bi-moon-fill"></i>
                        </button>*@

                        <select id="cultureSelect" class="form-select form-select-sm" style="width: auto; cursor: pointer;">
                            <option value="en" selected="@(currentCulture == "en" ? "selected" : null)">🇳🇿 @Localizer["English"]</option>
                            <option value="bg" selected="@(currentCulture == "bg" ? "selected" : null)">🇧🇬 @Localizer["Bulgarian"]</option>
                            <option value="de" selected="@(currentCulture == "de" ? "selected" : null)">🇩🇪 @Localizer["German"]</option>
                            <option value="fr" selected="@(currentCulture == "fr" ? "selected" : null)">🇫🇷 @Localizer["French"]</option>
                            <option value="es" selected="@(currentCulture == "es" ? "selected" : null)">🇦🇷 @Localizer["Spanish"]</option>
                        </select>

                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-grow-1 d-flex flex-column py-4">
        <main role="main" class="flex-grow-1">
            <div class="container-fluid px-0 mt-2">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
            </div>

            @RenderBody()
        </main>
    </div>

    @if (ViewBag.HideFooter != true)
    {
        <footer class="border-top py-4 mt-auto" style="background-color: var(--bg-card); color: var(--text-muted);">
            <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center">
                <div class="mb-2 mb-md-0">
                    &copy; 2026 - <span class="fw-bold" style="color: var(--accent);">AssetInsight</span>
                </div>
                <div>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none" style="color: var(--text-muted);">Privacy Policy</a>
                    <span class="mx-2">|</span>
                    <a asp-area="" asp-controller="Home" asp-action="ToS" class="text-decoration-none" style="color: var(--text-muted);">Terms of Service</a>
                </div>
            </div>
        </footer>
    }

    <div class="modal fade" id="notificationModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content shadow">
                <div class="modal-header border-bottom-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-bell me-2"></i>All Notifications</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-0" id="modalNotificationBody">
                </div>
                <div class="modal-footer bg-light border-top-0 justify-content-center">
                    <button type="button" id="markAllReadBtn" class="btn btn-outline-primary w-100" style="display: none;">
                        <i class="bi bi-check2-all me-1"></i> Mark all as read
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/autosize@4.0.2/dist/autosize.min.js"></script>
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>

    @if (User.Identity.IsAuthenticated)
    {
        <script>
            const connection = new signalR.HubConnectionBuilder().withUrl("/notificationHub").build();

            connection.on("ReceiveNotification", (message, url) => {
                let $badge = $("#notification-count");
                let count = parseInt($badge.text()) || 0;
                $badge.text(count + 1).show();

                const newNotificationHtml = `
                    <li>
                        <a class="dropdown-item py-3 border-bottom notification-item notification-unread"
                           href="${url}">
                            <div class="d-flex flex-column">
                                <small class="notification-date">Just now</small>
                                <span class="notification-text fw-bold">
                                    ${message}
                                </span>
                            </div>
                        </a>
                    </li>`;

                $("#notificationList .dropdown-header").after(newNotificationHtml);

                $("#no-notifications-msg").remove();
            });

            connection.start().catch(err => console.error(err.toString()));
        </script>
        <script>
            $('#notificationDropdown').on('show.bs.dropdown', function ()
            {
                $("#notification-count").hide().text("0");
            });
        </script>
        <script>
            $(document).on('click', '#markAllReadBtn', function() {
                fetch('/Notification/MarkAsRead', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    }
                })
                .then(() =>{
                   $('#notificationModal').trigger('show.bs.modal');

                   $("#notificationList .fw-bold").removeClass("fw-bold");

                   $("#notificationList .bg-primary-subtle").removeClass("bg-primary-subtle");
                });
            });
        </script>

        <script>
            async function loadUnreadCount() {
                try {
                    const res = await fetch('/Notification/GetUnreadCount');
                    const count = await res.json();

                    const badge = document.getElementById("notification-count");

                    if (count > 0) {
                        badge.textContent = count;
                        badge.style.display = "inline-block";
                    } else {
                        badge.style.display = "none";
                    }

                } catch (err) {
                    console.error(err);
                }
            }

            loadUnreadCount();
        </script>
        <script>
            $('#notificationModal').on('show.bs.modal', function () {
                const $body = $('#modalNotificationBody');
                const $markAllBtn = $('#markAllReadBtn');

                $body.html('<div class="text-center py-5"><div class="spinner-border text-primary"></div></div>');

                $.ajax({
                    url: '/Notification/GetFullNotificationsPartial',
                    type: 'GET',
                    success: function (data) {
                        $body.html(data);

                        const hasUnread = $(data).find('.bg-primary-subtle').length > 0;

                        if (hasUnread) {
                            $markAllBtn.show();
                        } else {
                            $markAllBtn.hide();
                        }
                    },
                    error: function () {
                        $body.html('<div class="text-danger text-center py-3">Failed to load.</div>');
                        $markAllBtn.hide();
                    }
                });
            });
        </script>
        <script>
            $(document).ready(function() {
                $('#viewAllBtn').on('click', function(e) {
                    e.preventDefault();

                    const dropdownToggle = document.getElementById('notificationDropdown');
                    const bsDropdown = bootstrap.Dropdown.getInstance(dropdownToggle);
                    if (bsDropdown) {
                        bsDropdown.hide();
                    }

                    const myModal = new bootstrap.Modal(document.getElementById('notificationModal'));
                    myModal.show();
                });
            });
        </script>
        <script>
            $(document).on('click', '#notificationList .notification-item', function (e) {

                const id = $(this).data('id');
                const url = $(this).attr('href');
                const $item = $(this);

                e.preventDefault();

                fetch(`/Notification/MarkAsRead/${id}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    }
                })
                .then(() => {

                    $item.removeClass('notification-unread');
                    $item.find('.notification-text').removeClass('fw-bold');

                    let $badge = $("#notification-count");
                    let count = parseInt($badge.text()) || 0;

                    if (count > 0) {
                        $badge.text(count - 1);
                    }

                    window.location.href = url;
                });
            });
        </script>
        <script>
            $('#modalNotificationBody').on('click', '.notification-link', function(e) {
                const id = $(this).data('id');
                const $link = $(this);

                fetch(`/Notification/MarkAsRead/${id}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    }
                })
                .then(response => {
                    if (response.ok) {
                        $link.closest('.list-group-item').removeClass('bg-primary-subtle');
                        $link.closest('.list-group-item').find('p').removeClass('fw-bold');
                    }
                })
                .then(() => {
                    $('#notificationModal').modal('hide');
                });
            });
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>