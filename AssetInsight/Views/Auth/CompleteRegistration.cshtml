@model ExternalLoginViewModel
@using AssetInsight.Models.Account
@using Microsoft.AspNetCore.Mvc.Localization

@{
    ViewData["Title"] = "Complete Registration";
}

<h1>Complete Registration</h1>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">External Login Info</h5>

                <p><strong>Login Provider:</strong> @Model.ProviderDisplayName (@Model.LoginProvider)</p>

                @if (!string.IsNullOrEmpty(Model.Email))
                {
                    <p><strong>Email:</strong> @Model.Email</p>
                }

                <p><strong>Username:</strong> @Model.UserName</p>

                <form method="post" asp-action="ExternalLoginCompletion" class="mt-3">
                    <input type="hidden" asp-for="LoginProvider" />
                    <input type="hidden" asp-for="ProviderDisplayName" />
                    <input type="hidden" asp-for="ReturnUrl" />
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="FirstName" />
                    <input type="hidden" asp-for="LastName" />

                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label">Username</label>
                        <input asp-for="UserName" class="form-control" value="@Model.UserName" />
                        <span asp-validation-for="UserName" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">Complete Registration</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}