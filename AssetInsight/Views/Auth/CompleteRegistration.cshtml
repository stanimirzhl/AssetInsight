@model ExternalLoginViewModel
@inject IViewLocalizer Localizer
@using AssetInsight.Models.Account
@using Microsoft.AspNetCore.Mvc.Localization

@{
    ViewData["Title"] = "Complete Registration";
}

<link rel="stylesheet" href="~/css/complete-registration.css"/>

<div class="wot-container">
    <div class="wot-card">

        <h3 class="text-center mb-4">@Localizer["ChooseUsernameHeading"]</h3>

        <form method="post" action="/complete-registration">

            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <input type="hidden" asp-for="LoginProvider" />
            <input type="hidden" asp-for="ProviderDisplayName" />
            <input type="hidden" asp-for="ReturnUrl" />
            <input type="hidden" asp-for="Email" />
            <input type="hidden" asp-for="FirstName" />
            <input type="hidden" asp-for="LastName" />

            <div class="username-container d-flex flex-column gap-3">
                <div class="username-left">
                    <label asp-for="UserName" class="form-label fw-bold"></label>
                    <input asp-for="UserName" id="usernameInput" class="form-control wot-input" autocomplete="off" />
                    <small id="usernameError" class="text-danger d-none mt-2"></small>
                </div>

                <div id="usernameSuggestions" class="username-suggestions d-none">
                    <small class="text-muted d-block mb-2">Suggestions:</small>
                </div>
            </div>

            <button id="continueBtn" class="btn wot-btn w-100" type="submit">
                @Localizer["Continue"]
            </button>

            @Html.AntiForgeryToken()
        </form>

    </div>
</div>

@section Scripts {
    <script>

        let timeout = null;

        const usernameInput = document.getElementById("usernameInput");
        const error = document.getElementById("usernameError");
        const suggestions = document.getElementById("usernameSuggestions");
        const continueBtn = document.getElementById("continueBtn");

        usernameInput.addEventListener("input", function(){

            clearTimeout(timeout);

            const username = this.value;

            timeout = setTimeout(() => {

                if(username.length === 0){
                    error.classList.add("d-none");
                    suggestions.classList.add("d-none");
                    continueBtn.disabled = true;
                    return;
                }

                fetch(`/Identity/Auth/CheckUsername?username=${username}`)
                .then(res => res.json())
                .then(data => {

                    if(data.available){

                        error.classList.add("d-none");
                        suggestions.classList.add("d-none");
                        continueBtn.disabled = false;

                    }
                    else{

                        error.innerText = data.message;
                        error.classList.remove("d-none");

                        suggestions.innerHTML =
                        data.suggestions.map(x =>
                        `<span class="suggest">${x}</span>`
                        ).join("");

                        suggestions.classList.remove("d-none");

                        continueBtn.disabled = true;
                    }

                });

            },200);

        });

        document.addEventListener("click", function(e){

            if(e.target.classList.contains("suggest")){

                const value = e.target.innerText;

                usernameInput.value = value;

                error.classList.add("d-none");
                suggestions.classList.add("d-none");

                continueBtn.disabled = false;

            }

        });

        window.addEventListener("load", function(){

            if(usernameInput.value.length > 0){
                usernameInput.dispatchEvent(new Event("input"));
            }

        });

    </script>
}