@using AssetInsight.Data.Models
@model IEnumerable<TradingStrategy>

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm p-4">
                <h3>Run Backtest</h3>
                <form asp-controller="Backtest" asp-action="Run" method="post">
                    <div class="mb-3">
                        <label class="form-label">Select Strategy</label>
                        <select name="strategyId" class="form-select" required>
                            <option value="">-- Choose a Strategy --</option>
                            @foreach (var s in Model)
                            {
                                <option value="@s.Id">@s.Name (@(s.UserId == null ? "Global" : "My Strategy"))</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Stock Symbol</label>
                        <input type="text" name="symbol" class="form-control" value="AAPL" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Initial Balance ($)</label>
                        <input type="number" name="initialBalance" class="form-control" value="10000" step="0.01" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Run Backtest</button>
                </form>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm p-4">
                <h3>Manage Strategies</h3>
                <p class="text-muted">Don't see a strategy you like?</p>
                <a asp-controller="Strategy" asp-action="Create" class="btn btn-success mb-3">Create New Custom Strategy</a>

                <hr />
                <h5>Quick Guide</h5>
                <ul class="text-secondary small">
                    <li><strong>Global Strategies:</strong> Pre-built by the system for testing.</li>
                    <li><strong>Custom Strategies:</strong> Created by you using our rule-builder.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}