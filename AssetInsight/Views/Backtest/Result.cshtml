@using AssetInsight.Models.Backtest
@model BacktestResultViewModel

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-end border-bottom border-secondary pb-3 mb-4">
        <div>
            <h1 class="fw-bold mb-0">Backtest Report</h1>
            <p class="text-muted mb-0">
                Strategy: <span class="text-accent fw-bold">@Model.StrategyName</span> |
                Asset: <span class="badge bg-secondary">@Model.Symbol</span> |
                Period: <span class="badge border border-secondary text-muted">@ViewData["TimeRange"]</span>
            </p>
        </div>
        <a asp-controller="Backtest" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Run Another
        </a>
    </div>

    <div class="row g-3 mb-5">
        @{
            var stats = new[] {
                ("Initial Capital", Model.InitialBalance, "$"),
                ("Final Value", Model.FinalBalance, "$"),
                ("Net Profit", Model.FinalBalance - Model.InitialBalance, "$"),
                ("Total Return", Model.ProfitPercentage, "%")
                };
        }
        @foreach (var stat in stats)
        {
            <div class="col-md-3">
                <div class="content-card h-100">
                    <h6 class="text-uppercase text-muted small fw-bold">@stat.Item1</h6>
                    <h4 class="fw-bold mb-0 @(stat.Item2 >= 0 ? "text-success" : "text-danger")">
                        @(stat.Item3 == "%" ? "" : stat.Item3)@stat.Item2.ToString("N2")@(stat.Item3 == "%" ? stat.Item3 : "")
                    </h4>
                </div>
            </div>
        }
    </div>

    <div class="content-card p-0">
        <div class="p-3 border-bottom border-secondary d-flex justify-content-between align-items-center">
            <h5 class="fw-bold mb-0">Execution Log</h5>
            <span class="badge bg-dark text-muted border border-secondary">Total Trades: @Model.TradeLogs.Count</span>
        </div>
        <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
            <table class="table table-dark table-hover align-middle mb-0">
                <thead style="background-color: var(--bg-main); position: sticky; top: 0; z-index: 1;">
                    <tr>
                        <th class="ps-4">Date</th>
                        <th>Type</th>
                        <th>Price</th>
                        <th class="text-end pe-4">Status/Balance</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.TradeLogs.Any())
                    {
                        @foreach (var log in Model.TradeLogs)
                        {
                            bool isBuy = log.Contains("BUY");
                            <tr>
                                <td class="ps-4 text-muted">@log.Split(':')[0]</td>
                                <td>
                                    <span class="badge @(isBuy ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">
                                        @(isBuy ? "BUY" : "SELL")
                                    </span>
                                </td>
                                <td class="fw-bold">$@(log.Contains("at") ? log.Split("at")[1].Split('|')[0].Trim() : "N/A")</td>
                                <td class="text-end pe-4 text-muted">@(log.Contains('|') ? log.Split('|')[1].Trim() : "Order Filled")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">No trades were executed during this time period. Try adjusting your strategy rules or extending the time period.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .content-card {
        background-color: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.5rem;
    }

    .text-accent {
        color: var(--accent);
    }

    .bg-success-subtle {
        background-color: rgba(25, 135, 84, 0.2);
    }

    .bg-danger-subtle {
        background-color: rgba(220, 53, 69, 0.2);
    }

    .table-dark {
        background-color: transparent !important;
        color: var(--text-main) !important;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(255, 255, 255, 0.05) !important;
    }
</style>