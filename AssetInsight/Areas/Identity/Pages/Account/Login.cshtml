@page
@using Microsoft.AspNetCore.Mvc.Localization
@using static AssetInsight.Data.Constants.DataConstants
@model LoginModel
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "Log in";
    ViewBag.HideFooter = true;
}

<link rel="stylesheet" href="~/css/login/login.css" />

<div class="auth-container">
    @if (Model.Step == LoginStep.Login)
    {
        <h1 class="auth-brand">Asset<span>Insight</span></h1>

        <div class="login-wrapper">
            <div class="login-card main-card">
                <form id="account" method="post">
                    <h2 class="card-title">@Localizer["LoginTitle"]</h2>
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.UserNameEmail" class="form-control" autocomplete="username" placeholder="name@example.com" />
                        <label asp-for="Input.UserNameEmail">@Localizer["UserName"]</label>
                        <span asp-validation-for="Input.UserNameEmail" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <div class="form-floating position-relative">
                            <input asp-for="Input.Password" id="password" class="form-control" autocomplete="current-password" placeholder="Password" />
                            <label asp-for="Input.Password">@Localizer["Password"]</label>
                            <span class="toggle-password" data-target="password">
                                <i id="eyeIcon" class="bi bi-eye-slash"></i>
                            </span>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="auth-options">
                        <small>
                            @Localizer["NoAccount"]
                            <a asp-route-returnUrl="@Model.ReturnUrl" asp-area="Identity" asp-page="/Account/Register">@Localizer["RegisterMessage"]</a>
                        </small>
                    </div>

                    <button type="submit" class="btn btn-primary-finance w-100 mt-3">@Localizer["LoginButton"]</button>
                </form>
            </div>

            @if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <div class="auth-divider">
                    <div class="vr"></div>
                </div>

                <div class="login-card external-card">
                    <div class="external-content">
                        <h5 class="external-title">@Localizer["OrSignUpWith"]</h5>
                        <div class="external-login-container">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <form method="post" asp-route-returnUrl="@Model.ReturnUrl" asp-controller="Auth" asp-action="ExternalLogin" class="w-100 mb-3">
                                    <button type="submit" name="provider" value="@provider.Name" class="btn provider-btn w-100">
                                        <span class="provider-icon-wrapper">
                                            @Model.GetProviderSvg(provider.Name)
                                        </span>
                                        <span class="ms-3">@provider.DisplayName</span>
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else if (Model.Step == LoginStep.ConfirmLink)
    {
        <div class="step-card-wrapper">
            <div class="login-card step-card">
                <div class="user-avatar">
                    <i class="bi bi-person-check"></i>
                </div>
                <h2 class="card-title">@Localizer["ExistingAccount"]</h2>

                <div class="info-group">
                    <div class="info-row">
                        <span class="label">@Localizer["Email"]</span>
                        <span class="value">@Model.ConfirmLink.Email</span>
                    </div>
                    <div class="info-row border-0">
                        <span class="label">@Localizer["UserName"]</span>
                        <span class="value">@Model.ConfirmLink.UserName</span>
                    </div>
                </div>

                <form method="post" asp-page-handler="ConfirmLink">
                    <input type="hidden" asp-for="ConfirmLink.Email" />
                    <input type="hidden" asp-for="ConfirmLink.Provider" />
                    <input type="hidden" asp-for="ConfirmLink.FullName" />
                    <button type="submit" class="btn btn-primary-finance w-100">@Localizer["MyAccount"]</button>
                </form>

                <a href="/Identity/Account/Login?clearlogin=true" class="btn-back mt-3">
                    <i class="bi bi-arrow-left"></i> @Localizer["LoginPage"]
                </a>
            </div>
        </div>
    }
    else if (Model.Step == LoginStep.EnterPassword)
    {
        <div class="step-card-wrapper">
            <div class="login-card step-card">
                <div class="user-avatar">
                    <i class="bi bi-shield-lock"></i>
                </div>
                <p class="description">
                    <strong>@Model.LinkExternal.FullName</strong><br />
                    @Html.Raw(string.Format(Localizer["Link"].Value, Model.LinkExternal.Provider))
                </p>

                <div class="info-row mb-4">
                    <span class="label">@Localizer["Email"]</span>
                    <span class="value">@Model.LinkExternal.Email</span>
                </div>

                <form method="post" asp-page-handler="LinkExternal">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="LinkExternal.Email" />
                    <input type="hidden" asp-for="LinkExternal.FullName" />
                    <input type="hidden" asp-for="LinkExternal.Provider" />

                    <div class="form-floating mb-3">
                        <input asp-for="LinkExternal.LinkPassword" id="password" class="form-control" type="password" placeholder="Password" />
                        <label asp-for="LinkExternal.LinkPassword">@Localizer["Password"]</label>
                        <span class="toggle-password" data-target="password">
                            <i id="eyeIcon" class="bi bi-eye-slash"></i>
                        </span>
                    </div>
                    <span asp-validation-for="LinkExternal.LinkPassword" class="text-danger"></span>

                    <button class="btn btn-primary-finance w-100">@Localizer["Continue"]</button>
                </form>

                <a href="/Identity/Account/Login?clearlogin=true" class="btn-back mt-3">
                    <i class="bi bi-arrow-left"></i> @Localizer["LoginPage"]
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}