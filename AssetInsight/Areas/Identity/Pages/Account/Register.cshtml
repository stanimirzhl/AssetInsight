@page
@using Microsoft.AspNetCore.Mvc.Localization
@model RegisterModel
@inject IViewLocalizer Localizer
@inject Microsoft.Extensions.Options.IOptions<IdentityOptions> IdentityOptions

@{
    ViewData["Title"] = "Register";
    ViewBag.HideFooter = true;
}

<link rel="stylesheet" href="~/css/login/login.css" />


<h1 class="auth-brand text-center">Asset<span>Insight</span></h1>

<div class="auth-container">
    <div class="login-wrapper">
        <div class="login-card main-card">
            <h2 class="card-title">@Localizer["RegisterTitle"]</h2>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <div class="row g-2">
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.FirstName" class="form-control" placeholder="First Name" />
                            <label asp-for="Input.FirstName">@Localizer["FirstName"]</label>
                            <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.LastName" class="form-control" placeholder="Last Name" />
                            <label asp-for="Input.LastName">@Localizer["LastName"]</label>
                            <span asp-validation-for="Input.LastName" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.UserName" class="form-control" placeholder="UserName" />
                    <label asp-for="Input.UserName">@Localizer["UserName"]</label>
                    <span asp-validation-for="Input.UserName" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="email" placeholder="Email" />
                    <label asp-for="Input.Email">@Localizer["Email"]</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3 position-relative">
                    <input asp-for="Input.Password" id="password" type="password" class="form-control pe-5" autocomplete="new-password" placeholder="Password" />
                    <label asp-for="Input.Password">@Localizer["Password"]</label>
                    <span class="toggle-password" data-target="password">
                        <i id="eyeIcon" class="bi bi-eye-slash"></i>
                    </span>
                </div>

                <div id="password-rules" class="rounded-3 p-3 mt-2 small" style="display:none;">
                    <ul class="mb-0 ps-3">
                        <li id="rule-length" class="text-danger">@string.Format(Localizer["PasswordTooShort"].Value, IdentityOptions.Value.Password.RequiredLength.ToString())</li>
                        <li id="rule-uppercase" class="text-danger">@Localizer["PasswordRequiresUpper"]</li>
                        <li id="rule-lowercase" class="text-danger">@Localizer["PasswordRequiresLower"]</li>
                        <li id="rule-number" class="text-danger">@Localizer["PasswordRequiresDigit"]</li>
                        <li id="rule-special" class="text-danger">@Localizer["PasswordRequiresNonAlphanumeric"]</li>
                    </ul>
                </div>

                <span id="validation" asp-validation-for="Input.Password" class="text-danger small"></span>

                <div class="form-floating mb-4 position-relative">
                    <input asp-for="Input.ConfirmPassword" type="password" id="confirmPassword" class="form-control pe-5" autocomplete="new-password" placeholder="Confirm Password" />
                    <label asp-for="Input.ConfirmPassword">@Localizer["ConfirmPassword"]</label>
                    <span class="toggle-password" data-target="confirmPassword">
                        <i class="bi bi-eye-slash"></i>
                    </span>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <button id="registerSubmit" type="submit" class="btn btn-primary-finance w-100 btn-lg">
                    @Localizer["RegisterButton"]
                </button>

                <div class="auth-options mt-3 text-center">
                    <small class="text-muted">
                        @Localizer["HaveAccount"] <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="accent-link">@Localizer["LoginMessage"]</a>
                    </small>
                </div>
            </form>
        </div>

        @if ((Model.ExternalLogins?.Count ?? 0) > 0)
        {
            <div class="auth-divider d-none d-lg-flex">
                <div class="vr"></div>
            </div>

            <div class="login-card external-card">
                <div class="external-content">
                    <h5 class="external-title">@Localizer["OrSignUpWith"]</h5>
                    <div class="d-grid gap-3">
                        @foreach (var provider in Model.ExternalLogins!)
                        {
                            <form method="post" asp-route-returnUrl="@Model.ReturnUrl" asp-controller="Auth" asp-action="ExternalLogin">
                                <button type="submit" name="provider" value="@provider.Name" class="btn provider-btn w-100">
                                    @Model.GetProviderSvg(provider.Name)
                                    <span class="ms-3">@provider.DisplayName</span>
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}