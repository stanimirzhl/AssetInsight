@{
    ViewData["Title"] = "Администрация";
}

<h1 class="mb-4 fw-bold text-center">Административно табло</h1>

<div class="row g-4 justify-content-center">
    <div class="col-12 col-sm-6 col-lg-3">
        <a href="@Url.Action("AllUsers", "Admin", new { area = "Admin" })" class="text-decoration-none text-dark">
            <div class="card h-100 shadow-sm border-0 hover-card text-center p-4">
                <i class="bi bi-people display-4 text-primary mb-3"></i>
                <h5 class="fw-bold">Потребители</h5>
                <p class="text-muted mb-0">Управлявай регистрираните потребители и техните роли.</p>
            </div>
        </a>
    </div>

    @if (User.IsInRole("Editor"))
    {
        <div class="col-12 col-sm-6 col-lg-3">
            <a href="@Url.Action("AllArticles", "Home", new { area = "" })" class="text-decoration-none text-dark">
                <div class="card h-100 shadow-sm border-0 hover-card text-center p-4">
                    <i class="bi bi-newspaper display-4 text-success mb-3"></i>
                    <h5 class="fw-bold">Новини</h5>
                    <p class="text-muted mb-0">Създавай, редактирай или изтривай новини.</p>
                </div>
            </a>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <a href="@Url.Action("All", "Category", new { area = "" })" class="text-decoration-none text-dark">
                <div class="card h-100 shadow-sm border-0 hover-card text-center p-4">
                    <i class="bi bi-tags display-4 text-warning mb-3"></i>
                    <h5 class="fw-bold">Категории</h5>
                    <p class="text-muted mb-0">Добавяй, редактирай или премахвай категории.</p>
                </div>
            </a>
        </div>
    }

    @if (User.IsInRole("Moderator"))
    {
        <div class="col-12 col-sm-6 col-lg-3">
            <a href="@Url.Action("All", "Comment", new { area = "" })" class="text-decoration-none text-dark">
                <div class="card h-100 shadow-sm border-0 hover-card text-center p-4">
                    <i class="bi bi-chat-left-text display-4 text-danger mb-3"></i>
                    <h5 class="fw-bold">Коментари</h5>
                    <p class="text-muted mb-0">Одобрявай или отхвърляй коментари преди публикуване.</p>
                </div>
            </a>
        </div>
    }
</div>

<style>
    .hover-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .hover-card:hover {
        transform: translateY(-5px);
        box-shadow: 0.5rem 0.5rem 1rem black;
    }
</style>