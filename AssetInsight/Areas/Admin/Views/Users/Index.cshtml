@using AssetInsight.Areas.Admin.Models
@using InfoSurge.Areas.Admin.Models.Users
@model IEnumerable<UserListViewModel>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">User Management</h2>
        <a asp-action="Create" class="btn btn-accent"><i class="bi bi-person-plus"></i> Add New User</a>
    </div>

    <div class="content-card p-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
                <thead style="background-color: var(--bg-main);">
                    <tr>
                        <th class="ps-4">Name / Username</th>
                        <th>Email</th>
                        <th>Roles</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <span class="fw-bold d-block">@user.FullName</span>
                                <small class="text-muted">@user.Username</small>
                            </td>
                            <td class="text-muted">@user.Email</td>
                            <td>
                                @if (user.Roles.Any())
                                {
                                    foreach (var role in user.Roles)
                                    {
                                        <span class="badge bg-secondary me-1">@role</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted small">None</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                    <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete @user.Username?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .content-card {
        background-color: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
    }

    .btn-accent {
        background-color: var(--accent) !important;
        color: white !important;
    }
</style>