@using AssetInsight.Areas.Admin.Models
@using InfoSurge.Areas.Admin.Models.Users
@model UserEditViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="content-card p-4">
                <h3 class="mb-4">Edit User: <span class="text-accent">@Model.Username</span></h3>

                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label text-muted"></label>
                            <input asp-for="FirstName" class="form-control custom-input" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label text-muted"></label>
                            <input asp-for="LastName" class="form-control custom-input" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label text-muted"></label>
                        <input asp-for="Username" class="form-control custom-input" />
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label text-muted"></label>
                        <input asp-for="Email" class="form-control custom-input" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted d-block">Assign Roles</label>
                        <div class="d-flex flex-wrap gap-3">
                            @foreach (var role in Model.AllRoles)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox"
                                           name="SelectedRoles"
                                           value="@role.Value"
                                           id="role_@role.Value"
                                           @(Model.SelectedRoles.Contains(role.Value) ? "checked" : "") />
                                    <label class="form-check-label text-main" for="role_@role.Value">
                                        @role.Text
                                    </label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-accent px-4">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .content-card {
        background-color: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 12px;
    }

    .custom-input {
        background-color: var(--bg-main) !important;
        border: 1px solid var(--border) !important;
        color: var(--text-main) !important;
    }

    .btn-accent {
        background-color: var(--accent) !important;
        color: white !important;
    }

    .text-accent {
        color: var(--accent);
    }
</style>